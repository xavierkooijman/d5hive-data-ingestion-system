# Example environment file for d5hive-ingestion-system
# Copy to .env and fill in your secrets

# Fernet key for Airflow (generate with the command below)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=<your_fernet_key_here>
AIRFLOW__API_AUTH__JWT_SECRET=<your_jwt_secret_here>

# API keys
TOM_TOM_API_KEY=<your_tomtom_api_key_here>
OPENWEATHERMAP_API_KEY=<your_openweathermap_api_key_here>

# Destinations (passwords / credentials)
CRATEDB_PASSWORD=<your_cratedb_password_here>
AIVEN_PASSWORD=<your_aiven_password_here>
TIDB_PASSWORD=<your_tidb_password_here>

# Email (Gmail app password for SMTP or Resend API key)
EMAIL_PASSWORD=<your_email_app_password_here>
RESEND_API_KEY=<your_resend_api_key_here>

# Observability (optional) base64-encoded credentials for Grafana Cloud Loki and Metrics
LOKI_AUTH=<your_loki_auth_here>
GRAFANA_METRICS_AUTH=<your_grafana_metrics_auth_here>
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
